# Known hosts for remote sync
# This file is managed by puppet
<%-
resources = scope.call_function('puppetdb_query', [[
  'from',
  'resources',
  [
    'and',
    ['=', 'type', 'Sshkey'],
    ['=', 'exported', true],
    ['=', ['parameter', 'ensure'], 'present'],
  ]
]])

resources.sort_by { |r| r['certname'] }.each do |resource|
  parameters = resource['parameters']
  aliases = Array(parameters['host_aliases'])
    .reject { |el| el =~ /^---/ }
    .join(',')
-%>
<%= resource['certname'] %>,<%= aliases %> <%= parameters['type'] %> <%= parameters['key'] %>
<%-
end
-%>
