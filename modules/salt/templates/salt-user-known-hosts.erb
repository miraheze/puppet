# This file is managed by puppet
<%-
resources = scope.call_function('puppetdb_query', [[
  'from',
  'resources',
  [
    'and',
    ['=', 'type', 'Sshkey'],
    ['=', 'exported', true]
  ]
]])

resources
  .sort_by { |r| r['certname'] }
  .each do |resource|

  parameters = resource['parameters']
  next unless parameters['ensure'] == 'present'

  aliases = parameters['host_aliases']
    .reject { |el| el =~ /^---/ }
    .join(',')
-%>
<%= resource['certname'] %>,<%= aliases %> <%= parameters['type'] %> <%= parameters['key'] %>
<%-
end
-%>
